# ================================================================
# Startup Copilot OS — Environment Variables Template
# ================================================================

# ── OpenAI ───────────────────────────────────────────────────────
VITE_OPENAI_API_KEY=

# ── Google Gemini (optional) ─────────────────────────────────────
VITE_GEMINI_API_KEY=

# ── Live integrations (optional) ─────────────────────────────────
VITE_GITHUB_TOKEN=
VITE_GITHUB_REPO=
VITE_STRIPE_SECRET_KEY=
VITE_SLACK_WEBHOOK_URL=

# ── Email (optional — leave approval emails) ─────────────────────
# Get a free key at https://resend.com — without it, Approve opens your mail app
RESEND_API_KEY=
RESEND_FROM_EMAIL=Startup Copilot OS <onboarding@resend.dev>

# ── Supabase (set ENABLED=true to use cloud auth/sync) ───────────
VITE_SUPABASE_ENABLED=true
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# ── AgentSearch (https://github.com/brcrusoe72/agent-search) ─────
# npm run agent-search:prepare && npm run agent-search:up
VITE_AGENT_SEARCH_URL=http://127.0.0.1:3939
AGENT_SEARCH_URL=http://127.0.0.1:3939
AGENT_SEARCH_TOKEN=
